# Frontend proof provider mode
# mock-http: local mock proof server
# midnight-http: Midnight bridge/prover API
NEXT_PUBLIC_PROOF_PROVIDER=mock-http

# Mock server base and paths
NEXT_PUBLIC_PROOF_API_URL=http://localhost:9090
NEXT_PUBLIC_PROOF_PROVE_PATH=/prove
NEXT_PUBLIC_PROOF_VERIFY_PATH=/verify

# Midnight bridge base and paths
# Set these when switching to a real Midnight bridge service.
NEXT_PUBLIC_MIDNIGHT_API_URL=http://localhost:9090
NEXT_PUBLIC_MIDNIGHT_PROVE_PATH=/prove
NEXT_PUBLIC_MIDNIGHT_VERIFY_PATH=/verify
