# Midnight network — must be one of: preprod, undeployed, preview, mainnet
# Your Lace wallet is funded on preprod, so use preprod
NEXT_PUBLIC_MIDNIGHT_NETWORK=preprod

# Midnight node RPC (fill in after deployment)
NEXT_PUBLIC_MIDNIGHT_NODE_URL=https://indexer.midnight-testnet.io

# Contract address (fill in after deploy.mjs succeeds)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Proof Server (running via docker-compose)
NEXT_PUBLIC_PROOF_SERVER_URL=http://localhost:6300
